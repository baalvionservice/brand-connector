
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user identity and role information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["BRAND", "CREATOR", "ADMIN"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "PENDING"] },
        "isVerified": { "type": "boolean" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "campaigns": { "type": "boolean" },
            "payments": { "type": "boolean" },
            "messages": { "type": "boolean" },
            "system": { "type": "boolean" }
          }
        },
        "twoFactorEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "CreatorProfile": {
      "title": "Creator Profile",
      "description": "Detailed profile for creative talent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "niches": { "type": "array", "items": { "type": "string" } },
        "socialStats": { "type": "object" },
        "baseRates": { "type": "object" },
        "packages": { "type": "array" },
        "location": { "type": "string" },
        "rating": { "type": "number" },
        "visibility": { "type": "string", "enum": ["PUBLIC", "PRIVATE"] },
        "isVerified": { "type": "boolean" },
        "verificationStatus": { "type": "string", "enum": ["UNVERIFIED", "PENDING", "VERIFIED", "FLAGGED"] },
        "authenticityScore": { "type": "number" },
        "privacySettings": {
          "type": "object",
          "properties": {
            "canMessage": { "type": "string" },
            "canSeeRates": { "type": "string" }
          }
        },
        "payoutAccounts": {
          "type": "array",
          "items": { "type": "object" }
        },
        "onboardingStatus": { "type": "string", "enum": ["PENDING", "IN_PROGRESS", "COMPLETED"] },
        "onboardingStep": { "type": "number" },
        "payoutMethod": { "type": "object" },
        "portfolioSamples": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "username"]
    },
    "BrandProfile": {
      "title": "Brand Profile",
      "description": "Detailed profile for brands creating campaigns.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "companyName": { "type": "string" },
        "industry": { "type": "string" },
        "website": { "type": "string" },
        "teamSize": { "type": "string" },
        "plan": { "type": "string", "enum": ["STARTER", "GROWTH", "ENTERPRISE"] },
        "brandGuidelines": { "type": "string" },
        "logoUrl": { "type": "string" },
        "socialLinks": { "type": "object" },
        "gstNumber": { "type": "string" },
        "billingAddress": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["UNVERIFIED", "PENDING", "VERIFIED"] },
        "apiKeys": { "type": "array", "items": { "type": "string" } },
        "defaultBriefTemplate": { "type": "string" },
        "onboardingStatus": { "type": "string", "enum": ["PENDING", "IN_PROGRESS", "COMPLETED"] },
        "onboardingStep": { "type": "number" },
        "billingMethod": { "type": "object" }
      },
      "required": ["id", "userId", "companyName"]
    },
    "FlaggedContent": {
      "title": "Flagged Content",
      "description": "Submissions flagged for manual safety review.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "deliverableId": { "type": "string" },
        "campaignId": { "type": "string" },
        "creatorId": { "type": "string" },
        "brandId": { "type": "string" },
        "reason": { "type": "string" },
        "flagType": { "type": "string", "enum": ["USER_REPORT", "AUTO_KEYWORD", "AI_DETECTION"] },
        "riskFactor": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "CLEARED", "REMOVED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles."
    },
    "/creators/{creatorId}": {
      "schema": "CreatorProfile",
      "description": "Creator specific details."
    },
    "/brands/{brandId}": {
      "schema": "BrandProfile",
      "description": "Brand specific details."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app user alerts."
    },
    "/flagged_content/{flagId}": {
      "schema": "FlaggedContent",
      "description": "Moderation review queue items."
    }
  }
}
