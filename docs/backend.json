
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user identity and role information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["BRAND", "CREATOR", "ADMIN"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "email": { "type": "boolean" },
            "push": { "type": "boolean" },
            "marketing": { "type": "boolean" }
          }
        },
        "twoFactorEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat session between two or more participants.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastSenderId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "unreadCounts": { "type": "object" }
      },
      "required": ["id", "participantIds", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message within a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "attachmentUrl": { "type": "string" },
        "attachmentType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "conversationId", "senderId", "createdAt"]
    },
    "CreatorProfile": {
      "title": "Creator Profile",
      "description": "Detailed profile for creative talent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "niches": { "type": "array", "items": { "type": "string" } },
        "socialStats": { "type": "object" },
        "baseRates": { "type": "object" },
        "location": { "type": "string" },
        "rating": { "type": "number" },
        "onboardingStatus": { "type": "string", "enum": ["PENDING", "IN_PROGRESS", "COMPLETED"] },
        "onboardingStep": { "type": "number" },
        "payoutMethod": { "type": "object" },
        "portfolioSamples": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "username"]
    },
    "BrandProfile": {
      "title": "Brand Profile",
      "description": "Detailed profile for brands creating campaigns.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "companyName": { "type": "string" },
        "industry": { "type": "string" },
        "website": { "type": "string" },
        "teamSize": { "type": "string" },
        "plan": { "type": "string", "enum": ["STARTER", "GROWTH", "ENTERPRISE"] },
        "brandGuidelines": { "type": "string" },
        "logoUrl": { "type": "string" },
        "onboardingStatus": { "type": "string", "enum": ["PENDING", "IN_PROGRESS", "COMPLETED"] },
        "onboardingStep": { "type": "number" },
        "billingMethod": { "type": "object" }
      },
      "required": ["id", "userId", "companyName"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A marketing campaign created by a brand.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "brandId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "objectives": { "type": "array", "items": { "type": "string" } },
        "targetAudience": { "type": "string" },
        "niches": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["DRAFT", "ACTIVE", "PAUSED", "COMPLETED", "CANCELLED"] },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "deliverablesCount": { "type": "number" }
      },
      "required": ["id", "brandId", "title", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "A proposal submitted by a creator for a campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "campaignId": { "type": "string" },
        "creatorId": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "REVIEWING", "ACCEPTED", "REJECTED"] },
        "pitch": { "type": "string" },
        "proposedBudget": { "type": "number" },
        "proposedTimeline": { "type": "string" },
        "sampleUrls": { "type": "array", "items": { "type": "string" } },
        "appliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "campaignId", "creatorId", "status"]
    },
    "Deliverable": {
      "title": "Deliverable",
      "description": "An asset submitted by a creator for a campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "applicationId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "SUBMITTED", "REVISION_REQUESTED", "APPROVED"] },
        "submissionUrl": { "type": "string" },
        "feedback": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "applicationId", "title", "status"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "Financial balance for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "availableBalance": { "type": "number" },
        "pendingBalance": { "type": "number" },
        "currency": { "type": "string" }
      },
      "required": ["id", "userId", "availableBalance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial movement.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "walletId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["CREDIT", "DEBIT"] },
        "status": { "type": "string", "enum": ["PENDING", "COMPLETED", "FAILED"] },
        "description": { "type": "string" },
        "payoutMethod": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "walletId", "amount", "type", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "An in-app alert for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["CAMPAIGN", "PAYMENT", "MESSAGE", "SYSTEM"] },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "type", "read"]
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles."
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat conversations metadata."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual chat messages."
    },
    "/creators/{creatorId}": {
      "schema": "CreatorProfile",
      "description": "Creator specific details."
    },
    "/brands/{brandId}": {
      "schema": "BrandProfile",
      "description": "Brand specific details."
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Brand campaigns."
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Proposals submitted by creators."
    },
    "/deliverables/{deliverableId}": {
      "schema": "Deliverable",
      "description": "Submission assets for campaigns."
    },
    "/wallets/{walletId}": {
      "schema": "Wallet",
      "description": "User wallet balances."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Ledger of all financial transactions."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app user alerts."
    }
  }
}
